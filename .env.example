# 是否优先使用本地首页内容。
# true: 读取 src/data/home-page-content.ts
# false: 通过 src/services/home-page-service.ts 请求真实接口
VITE_USE_LOCAL_HOME_CONTENT=true

# 是否优先使用本地关于页内容。
VITE_USE_LOCAL_ABOUT_CONTENT=true

# 是否优先使用本地文章归档页内容。
VITE_USE_LOCAL_POSTS_CONTENT=true

# 是否优先使用本地文章详情页内容。
# true: 读取 src/content/posts/*.md 与 src/data/posts-page-content.ts
# false: 通过 src/services/post-detail-page-service.ts 请求真实接口
VITE_USE_LOCAL_POST_DETAIL_CONTENT=true

# 真实接口基础地址。
# 可以是相对地址（如 /api），也可以是完整域名。
VITE_API_BASE_URL=/api
